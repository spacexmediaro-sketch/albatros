generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH.JS MODELS ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── BUSINESS MODELS ─────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  phone     String?   @unique
  name      String?
  image     String?
  password  String?
  role      Role      @default(CLIENT)
  cars      Car[]
  bookings  Booking[]
  accounts  Account[]
  sessions  Session[]
  blogPosts BlogPost[]
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([phone])
}

enum Role {
  CLIENT
  ADMIN
  MECHANIC
  RECEPTIONIST
}

model Car {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vin         String?      @unique
  make        String
  model       String
  year        Int
  fuel        Fuel
  km          Int?
  plateNumber String?
  itpExpires  DateTime?
  rcaExpires  DateTime?
  lastService DateTime?
  bookings    Booking[]
  serviceJobs ServiceJob[]
  reminders   Reminder[]
  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([plateNumber])
}

enum Fuel {
  DIESEL
  BENZINA
  HIBRID
  ELECTRIC
}

model Service {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  shortDesc   String
  fullContent String    @db.Text
  durationMin Int
  priceFrom   Int?
  category    String
  icon        String?
  seoTitle    String?
  seoDesc     String?
  published   Boolean   @default(true)
  bookings    Booking[]
  createdAt   DateTime  @default(now())

  @@index([slug])
  @@index([category])
}

model Booking {
  id          String        @id @default(cuid())
  userId      String?
  user        User?         @relation(fields: [userId], references: [id])
  carId       String?
  car         Car?          @relation(fields: [carId], references: [id])
  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id])
  guestName   String?
  guestPhone  String?
  scheduledAt DateTime
  status      BookingStatus @default(PENDING)
  notes       String?
  source      String?
  createdAt   DateTime      @default(now())

  @@index([userId])
  @@index([serviceId])
  @@index([scheduledAt])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model ServiceJob {
  id             String            @id @default(cuid())
  trackingCode   String            @unique
  carId          String
  car            Car               @relation(fields: [carId], references: [id])
  receivedAt     DateTime          @default(now())
  estimatedReady DateTime?
  status         JobStatus
  totalCost      Int?
  events         ServiceJobEvent[]

  @@index([trackingCode])
  @@index([status])
  @@index([carId])
}

enum JobStatus {
  RECEPTIONAT
  IN_DIAGNOZA
  ASTEAPTA_PIESE
  IN_REPARATIE
  IN_PROBA
  FINALIZAT
  PREDAT
}

model ServiceJobEvent {
  id        String     @id @default(cuid())
  jobId     String
  job       ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status    JobStatus
  message   String?
  photoUrls String[]   @default([])
  createdBy String?
  createdAt DateTime   @default(now())

  @@index([jobId])
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String    @db.Text
  coverImage  String?
  category    String
  tags        String[]  @default([])
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  published   Boolean   @default(false)
  publishedAt DateTime?
  seoTitle    String?
  seoDesc     String?
  readingTime Int?
  views       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([slug])
  @@index([category])
  @@index([published])
}

model Estimate {
  id           String   @id @default(cuid())
  userId       String?
  carInfo      Json
  imageUrls    String[]
  aiAnalysis   Json
  estimatedMin Int
  estimatedMax Int
  status       String
  reviewedBy   String?
  finalQuote   Int?
  createdAt    DateTime @default(now())

  @@index([status])
}

model Reminder {
  id       String       @id @default(cuid())
  carId    String
  car      Car          @relation(fields: [carId], references: [id], onDelete: Cascade)
  type     ReminderType
  dueDate  DateTime
  notified Boolean      @default(false)

  @@index([carId])
  @@index([dueDate])
  @@index([notified])
}

enum ReminderType {
  ITP
  RCA
  REVIZIE_KM
  REVIZIE_TIMP
}
